generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANT ORGANIZATION (ISP Company)
// ============================================
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  email       String
  phone       String?
  address     String?
  country     String   @default("Tanzania")
  currency    String   @default("TZS")
  taxRate     Float    @default(18.0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         OrgUser[]
  customers     Customer[]
  devices       Device[]
  plans         Plan[]
  subscriptions Subscription[]
  invoices      Invoice[]
  payments      Payment[]
  usageRecords  UsageRecord[]
  paymentGateways PaymentGateway[]
  notifications  Notification[]
}

// ============================================
// PAYMENT GATEWAY CONFIGURATION (Pesapal, etc.)
// ============================================
model PaymentGateway {
  id             String   @id @default(cuid())
  organizationId String
  gateway        String   @default("pesapal") // pesapal, flutterwave, stripe
  consumerKey    String?
  consumerSecret String?
  apiKey         String?
  isLive         Boolean  @default(false) // sandbox vs live
  isEnabled      Boolean  @default(true)
  callbackUrl    String?
  ipnUrl         String?
  configJson     String?  // additional config as JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================
// ORGANIZATION USERS (Staff with RBAC)
// ============================================
model OrgUser {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  password       String?
  role           String   @default("agent") // admin, agent, viewer
  avatar         String?
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  receivedNotifications Notification[] @relation("UserNotifications")
}

// ============================================
// CUSTOMER / SUBSCRIBER
// ============================================
model Customer {
  id             String   @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String
  email          String?
  phone          String
  address        String?
  city           String?
  region         String?
  status         String   @default("active") // active, suspended, disconnected, trial
  balance        Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  payments      Payment[]
  usageRecords  UsageRecord[]
  invoices      Invoice[]
  notifications Notification[]
}

// ============================================
// NETWORK DEVICES (Universal - MikroTik, TP-Link, Huawei, ZTE, Cambium, etc.)
// ============================================
model Device {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  // Device vendor/brand
  type           String   // mikrotik, tplink, huawei, zte, cisco, juniper, ubiquiti, cambium, nokia, ericsson, generic
  // Device category
  category       String   @default("router") // router, switch, access_point, ont, olt, modem, firewall, radio, balancer, gateway
  model          String?
  ipAddress      String
  port           Int      @default(8728)
  // Connection protocols
  connectionProtocol String @default("api") // api, snmp, ssh, rest, tr069, telnet
  apiUser        String
  apiPassword    String
  // SNMP-specific
  snmpVersion    String?  // v1, v2c, v3
  snmpCommunity  String?  // public, private
  // SSH-specific
  sshPort        Int?
  sshKey         String?
  // TR-069 specific (ONT/OLT)
  acsUrl         String?
  // Device info
  firmware       String?
  serialNumber   String?
  location       String?
  status         String   @default("online") // online, offline, warning, maintenance
  lastSeenAt     DateTime?
  totalBandwidth String?  // e.g. "1Gbps"
  // Health metrics
  cpuUsage       Float?   // percentage 0-100
  memoryUsage    Float?   // percentage 0-100
  uptime         Int?     // seconds
  temperature    Float?   // celsius
  // Capabilities (comma-separated)
  capabilities   String?  // bandwidth_shaping,pppoe_server,dhcp_server,firewall,vlan,qos,nat,routing,hotspot
  // Configuration profile name
  configProfile  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  interfaces        DeviceInterface[]
  provisioningRules ProvisioningRule[]
  subscriptions     Subscription[]
}

// ============================================
// DEVICE INTERFACES / PORTS
// ============================================
model DeviceInterface {
  id        String  @id @default(cuid())
  deviceId  String
  name      String  // e.g. "ether1", "sfp1", "gpon-olt-1"
  type      String? // ethernet, sfp, wireless, bridge, pon, gpon, epon, vdsl, adsl, pon_olt, pon_ont
  macAddress String?
  status    String  @default("up") // up, down, disabled
  speed     String? // e.g. "1Gbps"
  rxBytes   BigInt  @default(0)
  txBytes   BigInt  @default(0)
  // PON-specific
  opticalRxPower Float? // dBm (for ONT/OLT)
  opticalTxPower Float? // dBm
  distance        Float? // km (fiber distance)

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

// ============================================
// PROVISIONING RULES (Device-specific plan mapping)
// ============================================
model ProvisioningRule {
  id        String @id @default(cuid())
  deviceId  String
  planId    String?
  planName  String
  speedDown String? // e.g. "50Mbps"
  speedUp   String? // e.g. "10Mbps"
  dataCap   Int?    // MB, null = unlimited
  queueType String  @default("simple") // simple, pcq, tree, queue_tree
  priority  Int     @default(1)
  isActive  Boolean @default(true)

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  plan   Plan?  @relation(fields: [planId], references: [id])
}

// ============================================
// ISP PLANS / PACKAGES
// ============================================
model Plan {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  speedDown      String   // e.g. "50Mbps"
  speedUp        String   // e.g. "10Mbps"
  dataCap        Int?     // MB, null = unlimited
  priceMonthly   Float
  priceQuarterly Float?
  priceYearly    Float?
  setupFee       Float    @default(0)
  isActive       Boolean  @default(true)
  isPopular      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions     Subscription[]
  provisioningRules ProvisioningRule[]
}

// ============================================
// SUBSCRIPTIONS
// ============================================
model Subscription {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String
  planId         String
  deviceId       String?
  status         String   @default("active") // active, suspended, expired, cancelled
  startDate      DateTime @default(now())
  endDate        DateTime?
  billingCycle   String   @default("monthly") // monthly, quarterly, yearly
  autoRenew      Boolean  @default(true)
  username       String?  // PPPoE / login username
  password       String?  // PPPoE / login password
  ipAssignment   String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])
  device       Device?      @relation(fields: [deviceId], references: [id])
  invoices     Invoice[]
  usageRecords UsageRecord[]
}

// ============================================
// USAGE / BANDWIDTH RECORDS
// ============================================
model UsageRecord {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String
  subscriptionId String
  deviceId       String?
  date           DateTime @default(now())
  downloadBytes  BigInt   @default(0)
  uploadBytes    BigInt   @default(0)
  totalBytes     BigInt   @default(0)
  sessionTime    Int?     // seconds
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subscription Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

// ============================================
// INVOICES
// ============================================
model Invoice {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String
  subscriptionId String?
  invoiceNumber  String   @unique
  status         String   @default("pending") // pending, paid, partial, overdue, cancelled
  subtotal       Float    @default(0)
  tax            Float    @default(0)
  discount       Float    @default(0)
  total          Float    @default(0)
  dueDate        DateTime
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subscription Subscription?     @relation(fields: [subscriptionId], references: [id])
  lineItems   InvoiceLineItem[]
  payments     Payment[]
}

// ============================================
// INVOICE LINE ITEMS
// ============================================
model InvoiceLineItem {
  id         String @id @default(cuid())
  invoiceId  String
  description String
  quantity   Int    @default(1)
  unitPrice  Float
  total      Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ============================================
// PAYMENTS (with Pesapal gateway support)
// ============================================
model Payment {
  id                    String   @id @default(cuid())
  organizationId        String
  customerId            String
  invoiceId             String?
  amount                Float
  method                String   @default("cash") // cash, bank_transfer, mobile_money, card, pesapal, online
  // Specific payment channel (for Pesapal/mobile money)
  paymentChannel        String?  // mpesa, airtel_money, tigo_pesa, halotel, ttcl_pesa, visa, mastercard, pesapal_card, pesapal_bank
  // Pesapal specific fields
  gateway               String?  // pesapal, manual
  pesapalTrackingId     String?
  pesapalMerchantRef    String?
  pesapalPaymentMethod  String?  // M-PESA, AIRTEL MONEY, TIGO PESA, VISA, MASTERCARD, etc.
  // General
  reference             String?
  status                String   @default("completed") // completed, pending, failed, refunded, processing
  receiptNumber         String?
  notes                 String?
  paidAt                DateTime @default(now())
  createdAt             DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])
}

// ============================================
// NOTIFICATION
// ============================================
model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  customerId     String?
  type           String   // payment_received, invoice_overdue, subscription_expired, device_alert, system, welcome
  title          String
  message        String
  data           String?  // JSON string for additional data
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         OrgUser?    @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  customer     Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)
}
